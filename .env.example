# Client (Vite) — VAPID public key (URL-safe base64), must match server VAPID_PUBLIC_KEY
VITE_VAPID_PUBLIC_KEY=

# Web Push (serverless)
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_CONTACT_EMAIL=mailto:you@example.com

# Upstash Redis REST (push subscription storage)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
